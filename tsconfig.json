{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "sst": ["./path/to/virtual/sst/if/needed"],
      "sst/*": ["./path/to/virtual/sst/*"]
    },
    "types": ["node", "aws-lambda"]
  },
  "include": ["src/**/*.ts", "sst.config.ts"],
  "exclude": ["node_modules"]
}
